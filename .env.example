# Choose one or both providers
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Default model
#DEFAULT_MODEL=claude-sonnet-4-20250514
DEFAULT_MODEL=gpt-4o

# Logging
LOG_LEVEL=INFO

# Supabase (Postgres + REST). URL tùy chọn — nếu để trống sẽ dùng https://<SUPABASE_PROJECT_ID>.supabase.co
SUPABASE_PROJECT_ID=
# SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_PUBLIC_KEY=
SUPABASE_SECRET=

# AI Hook Logging (set by instructor)
AI_LOG_SERVER=https://ai-logs.note.transformerlabs.ai/api/ingest
AI_LOG_API_KEY=lMfm8NPzHVHlOtYx2kOQ7c9PTxJOB0E3DJbD_UBlsFw
AI_LOG_DIR=.ai-log

# Backend (FastAPI)
APP_NAME=Serene API
APP_VERSION=1.0.0
API_PREFIX=/v1

# Database
DATABASE_URL=
AUTO_CREATE_SCHEMA=false

# Auth and JWT
ACCESS_TOKEN_TTL_SECONDS=3600
REFRESH_TOKEN_TTL_DAYS=30
ADMIN_TOKEN_TTL_SECONDS=900
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ALGORITHM=RS256

# Cookies and CSRF
COOKIE_SECURE=true
COOKIE_DOMAIN=
CSRF_TRUSTED_ORIGINS=

# Admin security
ADMIN_ALLOWED_IPS=
ADMIN_LOGIN_EMAIL=
ADMIN_PASSWORD_HASH=
ADMIN_TOTP_SECRET=

# Rate limits
AUTH_RATE_LIMIT_PER_MINUTE=5
CHAT_RATE_LIMIT_PER_MINUTE=30
AUTH_LOCKOUT_THRESHOLD=5
AUTH_LOCKOUT_MINUTES=15

# Cache and Redis
REDIS_URL=redis://localhost:6379/0
PROFILE_CACHE_TTL_SECONDS=30

# LLM runtime
OPENAI_MODEL_ANALYST=gpt-4o-mini
OPENAI_MODEL_FRIEND=gpt-4o-mini
LLM_TIMEOUT_SECONDS=10.0

# Safety thresholds
DISTRESS_VOICE_HINT=0.8
DISTRESS_CRITICAL=0.9

# Neo4j
NEO4J_URI=
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
