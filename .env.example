# Choose one or both providers
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Default model
#DEFAULT_MODEL=claude-sonnet-4-20250514
DEFAULT_MODEL=gpt-4o-mini
OPENAI_REVIEW_MODEL=gpt-4o-mini

# Logging
LOG_LEVEL=INFO

# Supabase (Postgres + REST). URL tùy chọn — nếu để trống sẽ dùng https://<SUPABASE_PROJECT_ID>.supabase.co
SUPABASE_PROJECT_ID=
# SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_PUBLIC_KEY=
SUPABASE_SECRET=

# AI Hook Logging (set by instructor)
AI_LOG_SERVER=https://ai-logs.note.transformerlabs.ai/api/ingest
AI_LOG_API_KEY=lMfm8NPzHVHlOtYx2kOQ7c9PTxJOB0E3DJbD_UBlsFw
AI_LOG_DIR=.ai-log

# Backend (FastAPI)
APP_NAME=Serene API
APP_VERSION=1.0.0
API_PREFIX=/v1

# Database (để trống → SQLite `serene_local.db` trong thư mục chạy uvicorn, thường là `backend/`)
DATABASE_URL=
AUTO_CREATE_SCHEMA=false

# Auth and JWT
ACCESS_TOKEN_TTL_SECONDS=3600
REFRESH_TOKEN_TTL_DAYS=30
ADMIN_TOKEN_TTL_SECONDS=900
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ALGORITHM=RS256
# Local: nếu không có RSA ở trên, đặt chuỗi >= 16 ký tự để ký HS256 (không dùng production)
JWT_DEV_SECRET=

# OAuth / Social Login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/v1/auth/oauth/google/callback
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=http://127.0.0.1:8000/v1/auth/oauth/facebook/callback
OAUTH_STATE_TTL_SECONDS=600
FRONTEND_AUTH_REDIRECT_URL=http://127.0.0.1:5173/auth/callback

# Cookies and CSRF
# Local http://localhost: đặt false; production HTTPS: true
COOKIE_SECURE=false
COOKIE_DOMAIN=
CSRF_TRUSTED_ORIGINS=

# Admin security
ADMIN_ALLOWED_IPS=
ADMIN_LOGIN_EMAIL=
ADMIN_PASSWORD_HASH=
ADMIN_TOTP_SECRET=

# Rate limits
AUTH_RATE_LIMIT_PER_MINUTE=5
CHAT_RATE_LIMIT_PER_MINUTE=30
AUTH_LOCKOUT_THRESHOLD=5
AUTH_LOCKOUT_MINUTES=15

# Cache and Redis
REDIS_URL=redis://localhost:6379/0
PROFILE_CACHE_TTL_SECONDS=30

# LLM runtime
OPENAI_MODEL_ANALYST=gpt-4o-mini
OPENAI_MODEL_FRIEND=gpt-4o-mini
OPENAI_MODEL_FRIEND_FAST=gpt-4o-mini
LLM_TIMEOUT_SECONDS=10.0

# Safety thresholds
DISTRESS_VOICE_HINT=0.8
DISTRESS_CRITICAL=0.9
PROACTIVE_VOICE_AUTO_DISTRESS_THRESHOLD=0.8

# TTS: elevenlabs | auto (auto aliases to elevenlabs-only mode)
TTS_PROVIDER=elevenlabs
TTS_TIMEOUT_SECONDS=4.0

# ElevenLabs (requires ELEVENLABS_API_KEY; Redis recommended for daily char budget)
ELEVENLABS_FEATURE_ENABLED=true
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=iSFxP4Z6YNcx9OXl62Ic
# Multilingual (incl. Vietnamese): eleven_multilingual_v2
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
ELEVENLABS_TIMEOUT_SECONDS=9.0
ELEVENLABS_MAX_CHARS_PER_JOB=520
ELEVENLABS_USE_ONLY_ON_TIER=voice_recommended,critical
ELEVENLABS_MIN_DISTRESS=0.8
ELEVENLABS_MAX_CHARS_PER_USER_PER_DAY=12000

# Neo4j
NEO4J_URI=
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# Langfuse LLM observability (optional — leave blank to disable tracing)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

AUTH_EMAIL_VERIFY_TTL_MINUTES=30
AUTH_PASSWORD_RESET_TTL_MINUTES=30
AUTH_EMAIL_RESEND_COOLDOWN_SECONDS=60

# Public URLs used in email links
BACKEND_PUBLIC_BASE_URL=http://127.0.0.1:8000
FRONTEND_HOME_URL=http://127.0.0.1:5173/home
FRONTEND_RESET_PASSWORD_URL=http://127.0.0.1:5173/reset-password

# SMTP (for verification/reset emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_STARTTLS=true
SMTP_USE_SSL=false
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Serene
