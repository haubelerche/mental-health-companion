# ─────────────────────────────────────────────────────────────────────────────
# Environment variables required for Cloud Run deployment
# These are stored in Google Secret Manager (created by setup_cloudrun.sh)
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (Supabase) ────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres.YOURPROJECT:PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres

# ── OpenAI ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
DEFAULT_MODEL=gpt-4o-mini

# ── JWT Keys (RS256) ──────────────────────────────────────────────────────
JWT_ALGORITHM=RS256
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
...
-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
...
-----END PUBLIC KEY-----"

# ── Blaze TTS ──────────────────────────────────────────────────────────────
BLAZE_API=...
BLAZE_TTS_URL=https://api.blaze.vn/api/tts
BLAZE_TTS_MODEL=blaze-tts-1
BLAZE_TTS_OUTPUT_FORMAT=mp3

# ── Security ──────────────────────────────────────────────────────────────
COOKIE_SECURE=true
# After first deploy, add Cloud Run frontend URL here:
CSRF_TRUSTED_ORIGINS=https://serene-frontend-XXXX-as.a.run.app,https://serene-backend-XXXX-as.a.run.app
# Set to frontend Cloud Run URL to allow direct API access from browser
CORS_EXTRA_ORIGINS=https://serene-frontend-XXXX-as.a.run.app

# ── Admin ─────────────────────────────────────────────────────────────────
ADMIN_LOGIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=$2b$12$...
ADMIN_TOTP_SECRET=...

# ── External APIs ─────────────────────────────────────────────────────────
EXA_API_KEY=...

# ── App settings (set as plain env vars, not secrets) ─────────────────────
APP_NAME=Serene API
APP_VERSION=1.0.0
API_PREFIX=/v1
AUTO_CREATE_SCHEMA=false
LOG_LEVEL=INFO

# ── Optional: Neo4j Aura ──────────────────────────────────────────────────
# NEO4J_URI=neo4j+s://INSTANCE.databases.neo4j.io
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=...

# ── Optional: Redis (Cloud Memorystore) ───────────────────────────────────
# REDIS_URL=redis://INTERNAL_IP:6379/0
# (Rate limiting is fail-open when Redis is unavailable)
