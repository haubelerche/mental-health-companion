{
  "version": "1.0",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "name": "log-prompt",
            "command": "python scripts/log_hook.py",
            "timeout": 10,
            "statusMessage": "Logging Codex prompt"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "name": "log-stop",
            "command": "python scripts/log_hook.py",
            "timeout": 10,
            "statusMessage": "Logging Codex stop event"
          }
        ]
      }
    ]
  }
}